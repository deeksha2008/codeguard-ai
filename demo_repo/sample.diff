+    def process_payment(self, order_id: str, payment_method: str, amount: float) -> dict:
+        """
+        Process payment for an order.
+        Returns {"success": bool, "transaction_id": str, "message": str}
+        Raises PaymentError if payment fails.
+        """
+        order = self._orders.get(order_id)
+        if not order:
+            raise ValueError(f"Order {order_id} not found")
+        if order.status == "cancelled":
+            raise PaymentError("Cannot pay for a cancelled order")
+
+        expected = round(order.total(), 2)
+        if abs(amount - expected) > 0.01:
+            raise PaymentError(
+                f"Amount mismatch: expected {expected}, got {amount}"
+            )
+
+        VALID_METHODS = ["credit_card", "debit_card", "upi", "net_banking", "wallet"]
+        if payment_method not in VALID_METHODS:
+            raise PaymentError(f"Invalid payment method: {payment_method}")
+
+        import hashlib, time
+        txn_id = hashlib.sha256(f"{order_id}{time.time()}".encode()).hexdigest()[:16]
+        order.status = "confirmed"
+
+        return {
+            "success": True,
+            "transaction_id": txn_id,
+            "message": f"Payment of ₹{amount} processed via {payment_method}",
+        }
+
